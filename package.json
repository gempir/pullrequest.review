{
    "name": "pullrequestdotreview",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite dev --mode dev",
        "tsc": "tsc --noEmit",
        "check:fix": "biome check --write .",
        "check": "biome check .",
        "knip": "knip --include files,exports",
        "test": "bun test",
        "build": "vite build && cp dist/client/_shell.html dist/client/index.html",
        "serve": "vite preview",
        "worker:dev": "wrangler dev --config wrangler.jsonc",
        "worker:preview": "wrangler dev --config wrangler.jsonc --remote",
        "cf-typegen": "wrangler types",
        "deploy": "wrangler deploy --config wrangler.jsonc",
        "wrangler": "wrangler",
        "react-doctor": "react-doctor -y --verbose --offline src"
